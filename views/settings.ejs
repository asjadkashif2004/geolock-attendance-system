<%
const pageTitle = 'Admin Settings';
const pageDate  = 'Profile, security, notifications, and preferences';
%>
<%- include('partials/header', { pageTitle, pageDate, page: 'settings' }) %>

<style>
  .settings-hub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .settings-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .settings-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .sc-wide-2 { grid-column: span 2; }
  .sc-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: rgba(34, 197, 94, 0.1);
    color: #16a34a;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .sc-title { font-size: 15px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
  .sc-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.5; margin-bottom: 24px; flex: 1; }
  .sc-btn {
    align-self: flex-start;
    padding: 6px 16px;
    border-radius: 6px;
    font-size: 13px; font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #16a34a;
    background: transparent;
    transition: all 0.2s;
  }
  .sc-btn:hover { background: rgba(34, 197, 94, 0.1); border-color: #22c55e; }
  [data-theme="dark"] .sc-btn { color: #4ade80; border-color: rgba(74, 222, 128, 0.3); }
  [data-theme="dark"] .sc-btn:hover { background: rgba(74, 222, 128, 0.1); border-color: #4ade80; }
  
  .top-row-card {
    display: flex; flex-direction: column; justify-content: center;
  }
  .top-row-label { font-size: 11px; font-weight: 700; color: #16a34a; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
  
  @media (max-width: 900px) {
    .settings-hub-grid { grid-template-columns: 1fr; }
    .sc-wide-2 { grid-column: span 1; }
  }
</style>



<div class="settings-hub-grid">
  <!-- Top Row -->
  <div class="settings-card sc-wide-2 top-row-card">
    <div class="top-row-label">WORKSPACE CONTROLS</div>
    <div class="sc-title" style="font-size: 18px;">Admin Settings</div>
    <div class="sc-desc" style="margin-bottom: 0;">Keep your team operations, appearance, and payroll defaults aligned in one place.</div>
  </div>
  
  <div class="settings-card top-row-card" style="position: relative;">
    <button class="btn-icon" style="position:absolute;top:20px;right:20px;" onclick="document.getElementById('btnTheme').click()">🌙</button>
    <div class="top-row-label">APPEARANCE</div>
    <div class="sc-title" style="font-size: 16px;">Theme</div>
    <div class="sc-desc" style="margin-bottom: 0;">Switch between light and dark modes to match your working environment.</div>
  </div>

  <!-- Row 2 -->
  <div class="settings-card">
    <div class="sc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
    <div class="sc-title">Appearance</div>
    <div class="sc-desc">Brand palette, theme mode, and dashboard visual defaults.</div>
    <a href="/settings/appearance" class="sc-btn">Customize</a>
  </div>
  
  <div class="settings-card">
    <div class="sc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
    <div class="sc-title">Attendance Rules</div>
    <div class="sc-desc">Late threshold, auto-checkout, and geofence enforcement settings.</div>
    <a href="/settings/attendance" class="sc-btn">Review</a>
  </div>
  
  <div class="settings-card">
    <div class="sc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
    <div class="sc-title">Location Settings</div>
    <div class="sc-desc">Office radius, site mapping, and device sync preferences.</div>
    <a href="/settings/locations" class="sc-btn">Manage</a>
  </div>

  <!-- Row 3 -->
  <div class="settings-card">
    <div class="sc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
    <div class="sc-title">Payroll Settings</div>
    <div class="sc-desc">Pay cycle, overtime rates, and approval workflows.</div>
    <a href="/settings/payroll" class="sc-btn">Configure</a>
  </div>
  
  <div class="settings-card">
    <div class="sc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
    <div class="sc-title">Account Settings</div>
    <div class="sc-desc">Admin profile, permissions, MFA, and security preferences.</div>
    <a href="/settings/account" class="sc-btn">Update</a>
  </div>
  
  <div class="settings-card">
    <div class="sc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></div>
    <div class="sc-title">Logout</div>
    <div class="sc-desc">Sign out of the admin workspace and return to the employee view.</div>
    <a href="#" class="sc-btn" onclick="showToast('Logged out successfully', 'success')">Sign out</a>
  </div>
</div>

<%- include('partials/footer') %>
