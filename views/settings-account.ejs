<%
const pageTitle = 'Account Settings';
const pageDate  = 'Admin profile, permissions, MFA, and security preferences';
const actions = `
  <a href="/settings" class="btn btn-outline" style="text-decoration:none;">← Back to Settings</a>
`;
%>
<%- include('partials/header', { pageTitle, pageDate, page: 'settings', actions }) %>

<div class="settings-grid">
  <div class="card">
    <div class="card-title">Security & Authentication</div>
    <form action="/api/settings/password" method="POST">
      <div class="setting-group">
        <label class="setting-label">Current Password</label>
        <input class="setting-input" type="password" name="currentPassword" placeholder="••••••••" required />
      </div>
      <div class="setting-group">
        <label class="setting-label">New Password</label>
        <input class="setting-input" type="password" name="newPassword" placeholder="••••••••" required />
      </div>
      <div class="setting-group">
        <label class="setting-label">Confirm New Password</label>
        <input class="setting-input" type="password" name="confirmPassword" placeholder="••••••••" required />
      </div>
      <button type="submit" class="btn btn-outline" style="width:100%;justify-content:center;margin-bottom:16px;">Update Password</button>
    </form>
    <button class="btn btn-primary" style="margin-top: 10px;" onclick="showToast('Account settings saved','success')">Save Changes</button>
  </div>
</div>

<%- include('partials/footer') %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const msg = params.get('msg');
    const type = params.get('type') || 'success';
    if (msg) {
      showToast(msg, type);
      // Clean up URL
      window.history.replaceState({}, document.title, window.location.pathname);
    }
  });
</script>
