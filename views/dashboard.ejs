<%
const pageTitle = 'Dashboard';
const pageDate  = new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
%>
<%- include('partials/header', { pageTitle, pageDate, page }) %>

<!-- Stats -->
<div class="stats-grid">
  <div class="card" style="padding: 20px; display: flex; flex-direction: column; gap: 12px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
      <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(34, 197, 94, 0.1); color: #10b981; display: flex; align-items: center; justify-content: center;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <svg style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
    </div>
    <div>
      <div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 4px;">Total Employees</div>
      <div style="font-size: 24px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px;"><%= stats.totalEmployees %></div>
      <div style="font-size: 10px; color: #10b981;">Total registered</div>
    </div>
  </div>

  <div class="card" style="padding: 20px; display: flex; flex-direction: column; gap: 12px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
      <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(139, 92, 246, 0.1); color: #8b5cf6; display: flex; align-items: center; justify-content: center;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>
      <svg style="color: #10b981;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
    </div>
    <div>
      <div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 4px;">Present Today</div>
      <div style="font-size: 24px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px;"><%= stats.present %></div>
      <div style="font-size: 10px; color: #10b981;"><%= stats.totalEmployees ? ((stats.present / stats.totalEmployees) * 100).toFixed(1) : 0 %>% attendance rate</div>
    </div>
  </div>

  <div class="card" style="padding: 20px; display: flex; flex-direction: column; gap: 12px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
      <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(245, 158, 11, 0.1); color: #f59e0b; display: flex; align-items: center; justify-content: center;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <svg style="color: var(--text-muted);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </div>
    <div>
      <div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 4px;">Late Check-ins</div>
      <div style="font-size: 24px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px;"><%= stats.late %></div>
      <div style="font-size: 10px; color: var(--text-muted);"><%= stats.present ? ((stats.late / stats.present) * 100).toFixed(1) : 0 %>% of present</div>
    </div>
  </div>

  <div class="card" style="padding: 20px; display: flex; flex-direction: column; gap: 12px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
      <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(239, 68, 68, 0.1); color: #ef4444; display: flex; align-items: center; justify-content: center;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <svg style="color: #ef4444;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>
    </div>
    <div>
      <div style="font-size: 11px; color: var(--text-secondary); margin-bottom: 4px;">Absent Today</div>
      <div style="font-size: 24px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px;"><%= stats.absent %></div>
      <div style="font-size: 10px; color: var(--text-muted);"><%= stats.totalEmployees ? ((stats.absent / stats.totalEmployees) * 100).toFixed(1) : 0 %>% absence rate</div>
    </div>
  </div>
</div>

<!-- Charts + Summary -->
<div class="dashboard-grid">
  <!-- Weekly Bar Chart -->
  <div class="card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
      <div class="card-title" style="margin-bottom:0;">Weekly Attendance Overview</div>
      <div style="display:flex;gap:14px;font-size:11px;color:#64748b;">
        <span><span style="display:inline-block;width:10px;height:10px;background:#22c55e;border-radius:2px;margin-right:4px;vertical-align:middle;"></span>Present</span>
        <span><span style="display:inline-block;width:10px;height:10px;background:#F59E0B;border-radius:2px;margin-right:4px;vertical-align:middle;"></span>Late</span>
        <span><span style="display:inline-block;width:10px;height:10px;background:#EF4444;border-radius:2px;margin-right:4px;vertical-align:middle;"></span>Absent</span>
      </div>
    </div>
    <div class="chart-bar-wrap">
      <% weeklyData.forEach(function(d){ %>
      <div class="chart-bar-group">
        <div class="bars">
          <div class="bar bar-present" style="height:<%= (d.present/10)*130 %>px;" title="Present: <%= d.present %>"></div>
          <div class="bar bar-late"    style="height:<%= (d.late/10)*130 %>px;"    title="Late: <%= d.late %>"></div>
          <div class="bar bar-absent"  style="height:<%= (d.absent/10)*130 %>px;"  title="Absent: <%= d.absent %>"></div>
        </div>
        <span class="chart-day"><%= d.day %></span>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Donut Summary -->
  <div class="card">
    <div class="card-title">Today's Summary</div>
    <%
      const total   = stats.totalEmployees;
      const pPct    = total ? (stats.present/total*100).toFixed(1) : 0;
      const lPct    = total ? (stats.late/total*100).toFixed(1) : 0;
      const pOff    = 25;
      const lOff    = (100 - parseFloat(pPct) + 25).toFixed(1);
    %>
    <div class="donut-wrap">
      <svg width="130" height="130" viewBox="0 0 42 42">
        <circle cx="21" cy="21" r="15.92" fill="transparent" stroke="#f1f5f9" stroke-width="6"/>
        <circle cx="21" cy="21" r="15.92" fill="transparent" stroke="#22c55e" stroke-width="6"
          stroke-dasharray="<%= pPct %> <%= (100-parseFloat(pPct)).toFixed(1) %>"
          stroke-dashoffset="<%= pOff %>" />
        <circle cx="21" cy="21" r="15.92" fill="transparent" stroke="#F59E0B" stroke-width="6"
          stroke-dasharray="<%= lPct %> <%= (100-parseFloat(lPct)).toFixed(1) %>"
          stroke-dashoffset="<%= lOff %>" />
        <text x="21" y="21" text-anchor="middle" dominant-baseline="central" font-size="7" font-weight="700" fill="var(--text-primary)"><%= total %></text>
      </svg>
      <div class="donut-legend">
        <div class="legend-item"><span class="legend-dot" style="background:#22c55e;"></span>Present<span class="legend-val"><%= stats.present %></span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#F59E0B;"></span>Late<span class="legend-val"><%= stats.late %></span></div>
        <div class="legend-item"><span class="legend-dot" style="background:#EF4444;"></span>Absent<span class="legend-val"><%= stats.absent %></span></div>
      </div>
    </div>
  </div>
</div>

<!-- Dashboard Grid for Attendance & Location Overview -->
<div class="dashboard-grid">
  <!-- Recent Attendance -->
  <div class="card" style="display:flex; flex-direction:column;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <div class="card-title" style="margin-bottom:0;">Today's Attendance</div>
      <a href="/attendance" class="btn btn-outline" style="font-size:12px;padding:6px 14px; color: #8b5cf6; background: rgba(139,92,246,0.1); border-color: rgba(139,92,246,0.2);">View All</a>
    </div>
    <div style="flex:1; overflow-x:auto;">
      <div class="table-scroll">
      <table class="data-table">
        <thead>
          <tr>
            <th>USER ID</th><th>NAME</th><th>CHECK IN</th><th>ADDRESS</th><th>STATUS</th>
          </tr>
        </thead>
        <tbody>
          <% recentAttendance.forEach(function(r){ %>
          <tr>
            <td class="emp-id-cell" style="font-size:12px;" title="<%= r.user_id %>"><%= r.user_id ? r.user_id.substring(0,8) : '--' %></td>
            <td>
              <div class="emp-cell">
                <div class="emp-name" style="font-weight:600;"><%= r.emp ? r.emp.name : '--' %></div>
              </div>
            </td>
            <td><span style="font-size:13px; font-weight:600; color:var(--text-primary);"><%= r.check_in_time ? new Date(r.check_in_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : '--' %></span></td>
            <td><span style="color:#64748b;font-size:13px;"><%= r.address || '--' %></span></td>
            <td>
              <% if(r.status==='present'){ %><span class="badge badge-present"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12" style="margin-right:4px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>Present</span>
              <% } else if(r.status==='late'){ %><span class="badge badge-late"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12" style="margin-right:4px;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Late</span>
              <% } else { %><span class="badge badge-absent"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12" style="margin-right:4px;"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>Absent</span><% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
    </div>
  </div>

  <!-- Location Overview -->
  <div class="card" style="display:flex; flex-direction:column;">
    <div class="card-title" style="margin-bottom:16px;">Location Overview</div>
    <div style="display:flex; flex-direction:column; gap:12px; flex:1; max-height: 400px; overflow-y: auto; padding-right: 8px;">
      
      <% if (locations && locations.length > 0) { %>
        <% locations.forEach(loc => { %>
        <div style="background:var(--bg-page); border:1px solid var(--border); border-radius:12px; padding:16px; display:flex; flex-direction:column; gap:16px;">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <div style="display:flex; align-items:center; gap:8px;">
              <svg style="color:<%= loc.status === 'Active' ? '#10b981' : '#f59e0b' %>;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span style="font-weight:600; font-size:14px; color:var(--text-primary);"><%= loc.name %></span>
            </div>
            <svg style="color:var(--text-muted);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; font-size:12px; color:var(--text-muted);">
            <span><%= loc.address || 'Address not provided' %></span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; font-size:12px; color:var(--text-secondary); border-top:1px dashed var(--border); padding-top:12px;">
            <span>Employees</span>
            <span style="font-weight:700; color:#3b82f6; font-size:14px;"><%= loc.employees || 0 %></span>
          </div>
        </div>
        <% }) %>
      <% } else { %>
        <div style="font-size:13px; color:var(--text-muted); text-align:center; padding: 20px;">No locations found.</div>
      <% } %>

    </div>
  </div>
</div>

<!-- Payroll Summary -->
<div class="card payroll-card-wrap" style="margin-top:20px; display:flex; align-items:center; justify-content:space-between; padding:24px;">
  <div>
    <div class="card-title" style="margin-bottom:4px;">Payroll Summary</div>
    <div style="font-size:11px; color:var(--text-muted);">June 2026</div>
  </div>
  <div class="dash-pay-row" style="display:flex; gap:20px; flex:1; margin-left:40px; margin-right:40px;">
    <div class="dash-pay-tot">
      <div class="lbl">Total Hours</div>
      <div class="val"><%= payrollSummary.totalHours %></div>
    </div>
    <div class="dash-pay-reg">
      <div class="lbl">Regular Hours</div>
      <div class="val"><%= payrollSummary.regularHours %></div>
    </div>
    <div class="dash-pay-ot">
      <div class="lbl">Overtime Hours</div>
      <div class="val"><%= payrollSummary.overtimeHours %></div>
    </div>
    <div class="dash-pay-est">
      <div class="lbl">Est. Payroll</div>
      <div class="val"><%= payrollSummary.estPayroll %></div>
    </div>
  </div>
  <button class="btn btn-primary" style="background:#10b981; border:none; display:flex; align-items:center; gap:8px;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    Process Payroll
  </button>
</div>

<%- include('partials/footer') %>
