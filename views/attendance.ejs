<%
const pageTitle = 'Attendance Management';
const pageDate  = new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
%>
<%- include('partials/header', { pageTitle, pageDate, page }) %>

<!-- ── Stats ── -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon-wrap total">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </div>
    <div>
      <div class="stat-num" id="statTotal"><%= stats.total %></div>
      <div class="stat-label">Total Records</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap present">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="22" height="22"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <div>
      <div class="stat-num" id="statPresent"><%= stats.present %></div>
      <div class="stat-label">Present</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap late">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <div>
      <div class="stat-num" id="statLate"><%= stats.late %></div>
      <div class="stat-label">Late Arrivals</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap absent">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="22" height="22"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    </div>
    <div>
      <div class="stat-num" id="statAbsent"><%= stats.absent %></div>
      <div class="stat-label">Absent</div>
    </div>
  </div>
</div>

<!-- ── Filter Bar ── -->
<div class="filter-bar" style="gap:10px;">
  <div style="display:flex; align-items:center; gap:12px; flex:1; flex-wrap:wrap;">
    <div class="search-wrap" style="flex:1; min-width:200px; max-width:250px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input class="search-input" id="searchInput" type="text" placeholder="Search name, ID, department..." oninput="applyFilters()" />
    </div>
    <select class="filter-select" id="dateFilter" onchange="applyDatePeriod()">
      <option value="today">Today</option>
      <option value="yesterday">Yesterday</option>
      <option value="week">This Week</option>
      <option value="month">This Month</option>
    </select>
    <select class="filter-select" id="empFilter" onchange="applyFilters()">
      <option value="">All Employees</option>
      <% records.forEach(r => { %>
        <option value="<%= r.user_id %>"><%= r.emp ? r.emp.name : r.user_id.substring(0,8) %></option>
      <% }) %>
    </select>
    <select class="filter-select" id="locFilter" onchange="applyFilters()">
      <option value="">All Locations</option>
      <option value="Main Office">Main Office</option>
      <option value="Branch Office">Branch Office</option>
      <option value="Remote">Remote</option>
    </select>
    <select class="filter-select" id="statusFilter" onchange="applyFilters()">
      <option value="">All Statuses</option>
      <option value="Present">Present</option>
      <option value="Late">Late</option>
      <option value="Absent">Absent</option>
    </select>
  </div>
  <div style="display:flex; align-items:center; gap:8px; margin-right:12px;">
    <input type="checkbox" id="includePayrollCb" style="cursor:pointer;" />
    <label for="includePayrollCb" style="font-size:13px; color:var(--text-secondary); cursor:pointer; font-weight:500;">Include Payroll</label>
  </div>
  <button class="btn btn-primary" id="btnExport" onclick="exportCSV()" style="background:#10b981; border:none; display:flex; align-items:center; gap:8px;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    Export
  </button>
</div>

<!-- ── Attendance Table ── -->
<div class="table-wrap">
  <div class="table-scroll">
  <table class="data-table" id="attendanceTable">
    <thead>
      <tr>
        <th>USER ID</th><th>NAME</th><th>DEPARTMENT</th>
        <th>CHECK IN</th><th>ADDRESS</th><th>STATUS</th>
      </tr>
    </thead>
    <tbody id="tableBody"></tbody>
  </table>
  </div>
  <div id="emptyState" class="empty-state" style="display:none;">No records found.</div>
</div>

<script>
/* ─── Fetch real backend records instead of mock periodData ─────────────────── */
const rawRecords = <%- JSON.stringify(records || []) %>;
let currentRows = rawRecords;

function badgeHtml(status){
  if(status==='present') return `<span class="badge badge-present"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>Present</span>`;
  if(status==='late')    return `<span class="badge badge-late"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Late</span>`;
  return `<span class="badge badge-absent"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>Absent</span>`;
}

function renderTable(rows) {
  const q      = (document.getElementById('searchInput')?.value||'').toLowerCase();
  const status = document.getElementById('statusFilter')?.value||'';
  const loc    = document.getElementById('locFilter')?.value||'';
  const empId  = document.getElementById('empFilter')?.value||'';

  const filtered = rows.filter(r => {
    const rName = r.emp?.name || '';
    const rDept = r.emp?.department || '';
    const uId = r.user_id || '';
    const matchQ   = !q      || rName.toLowerCase().includes(q) || rDept.toLowerCase().includes(q) || uId.toLowerCase().includes(q);
    const matchSt  = !status || (r.status || '').toLowerCase() === status.toLowerCase();
    const matchLoc = !loc    || (r.address || '').toLowerCase().includes(loc.toLowerCase());
    const matchEmp = !empId  || r.user_id === empId;
    return matchQ && matchSt && matchLoc && matchEmp;
  });

  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = filtered.map(r => {
    const time = r.check_in_time ? new Date(r.check_in_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : '--';
    const initials = r.emp?.initials || 'U';
    const color = r.emp?.color || '#6B7280';
    const name = r.emp?.name || ('User ' + (r.user_id ? r.user_id.substring(0,6) : 'Unknown'));
    const dept = r.emp?.department || 'Unknown';
    const addr = r.address || '--';
    return `
    <tr>
      <td class="emp-id-cell" style="font-size:12px;" title="${r.user_id}">${r.user_id ? r.user_id.substring(0,8) : '--'}</td>
      <td><div class="emp-cell"><div class="emp-avatar" style="background:${color}">${initials}</div><div class="emp-name">${name.length > 15 ? name.slice(0,15)+'...' : name}</div></div></td>
      <td><span style="color:#64748b;font-size:13px;">${dept}</span></td>
      <td><span class="checktime">${time}</span></td>
      <td><div class="loc-cell">${addr!=='--'?'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>':''}${addr}</div></td>
      <td>${badgeHtml(r.status)}</td>
    </tr>`;
  }).join('');

  document.getElementById('emptyState').style.display = filtered.length === 0 ? '' : 'none';

  // Update stats
  document.getElementById('statTotal').textContent   = filtered.length;
  document.getElementById('statPresent').textContent = filtered.filter(r=>r.status==='present').length;
  document.getElementById('statLate').textContent    = filtered.filter(r=>r.status==='late').length;
  document.getElementById('statAbsent').textContent  = filtered.filter(r=>r.status==='absent').length;
}

function applyDatePeriod() {
  const period = document.getElementById('dateFilter').value;
  // Fallback to simple local filtering since mock periodData was removed
  renderTable(currentRows);
  const labels = { today:'Today', yesterday:'Yesterday', week:'This Week', month:'This Month' };
  showToast(`Showing records for: ${labels[period]}`, 'info');
}

function applyFilters() { renderTable(currentRows); }

function exportCSV() {
  const includePayroll = document.getElementById('includePayrollCb')?.checked;
  const headers = ['USER ID', 'Name', 'Department', 'Check In', 'Address', 'Status'];
  if (includePayroll) {
    headers.push('Monthly Salary ($)', 'Est. Daily Pay ($)');
  }
  const rows = [headers];

  const tbodyRows = document.querySelectorAll('#tableBody tr');
  if (tbodyRows.length === 0) {
    showToast('No data to export', 'error');
    return;
  }

  // We map from filtered currentRows to guarantee we get the same data
  const q = (document.getElementById('searchInput')?.value||'').toLowerCase();
  const status = document.getElementById('statusFilter')?.value||'';
  const loc = document.getElementById('locFilter')?.value||'';
  const empId = document.getElementById('empFilter')?.value||'';

  const filtered = currentRows.filter(r => {
    const rName = r.emp?.name || '';
    const rDept = r.emp?.department || '';
    const uId = r.user_id || '';
    const matchQ = !q || rName.toLowerCase().includes(q) || rDept.toLowerCase().includes(q) || uId.toLowerCase().includes(q);
    const matchSt = !status || r.status === status.toLowerCase();
    const matchLoc = !loc || r.address === loc;
    const matchEmp = !empId || r.user_id === empId;
    return matchQ && matchSt && matchLoc && matchEmp;
  });

  filtered.forEach(r => {
    const name = r.emp?.name || 'Unknown';
    const dept = r.emp?.department || 'Unknown';
    const time = r.check_in_time ? new Date(r.check_in_time).toLocaleString() : '--';
    const rowData = [r.user_id || '--', name, dept, time, r.address || '--', r.status || '--'];
    
    if (includePayroll) {
      const salary = r.emp?.monthly_salary || 0;
      const daily = (salary / 22).toFixed(2);
      rowData.push(salary, daily);
    }
    rows.push(rowData);
  });

  const csv = rows.map(r => r.map(c => '"' + c + '"').join(',')).join('\n');
  const a = document.createElement('a');
  a.href    = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
  a.download= 'attendance_' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
  showToast('CSV exported successfully!', 'success');
}

// Initial render
renderTable(currentRows);
</script>

<%- include('partials/footer') %>
