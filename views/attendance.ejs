    { empId:'EMP004', name:'James Wilson',    initials:'JW', color:'#EF4444', dept:'Sales',       checkIn:'--',       checkOut:'--',        hours:'--',     location:'--',            status:'Absent'  },
    { empId:'EMP005', name:'Lisa Anderson',   initials:'LA', color:'#10B981', dept:'HR',          checkIn:'09:00 AM', checkOut:'05:30 PM', hours:'8h 30m', location:'Branch Office', status:'Present' },
    { empId:'EMP006', name:'Robert Martinez', initials:'RM', color:'#3B82F6', dept:'Engineering', checkIn:'08:45 AM', checkOut:'05:00 PM', hours:'8h 15m', location:'Main Office',   status:'Present' },
    { empId:'EMP007', name:'Anna Thompson',   initials:'AT', color:'#EC4899', dept:'Marketing',   checkIn:'--',       checkOut:'--',        hours:'--',     location:'--',            status:'Absent'  },
    { empId:'EMP008', name:'David Kim',       initials:'DK', color:'#6366F1', dept:'Finance',     checkIn:'10:05 AM', checkOut:'06:00 PM', hours:'7h 55m', location:'Remote',        status:'Late'    },
  ],
  yesterday: [
    { empId:'EMP001', name:'Sarah Johnson',   initials:'SJ', color:'#8B5CF6', dept:'Engineering', checkIn:'09:05 AM', checkOut:'05:35 PM', hours:'8h 30m', location:'Main Office',   status:'Present' },
    { empId:'EMP002', name:'Michael Chen',    initials:'MC', color:'#06B6D4', dept:'Product',     checkIn:'09:30 AM', checkOut:'06:00 PM', hours:'8h 30m', location:'Main Office',   status:'Late'    },
    { empId:'EMP003', name:'Emily Davis',     initials:'ED', color:'#F59E0B', dept:'Design',      checkIn:'09:00 AM', checkOut:'05:30 PM', hours:'8h 30m', location:'Main Office',   status:'Present' },
    { empId:'EMP004', name:'James Wilson',    initials:'JW', color:'#EF4444', dept:'Sales',       checkIn:'08:50 AM', checkOut:'05:20 PM', hours:'8h 30m', location:'Main Office',   status:'Present' },
    { empId:'EMP005', name:'Lisa Anderson',   initials:'LA', color:'#10B981', dept:'HR',          checkIn:'--',       checkOut:'--',        hours:'--',     location:'--',            status:'Absent'  },
    { empId:'EMP006', name:'Robert Martinez', initials:'RM', color:'#3B82F6', dept:'Engineering', checkIn:'09:00 AM', checkOut:'05:30 PM', hours:'8h 30m', location:'Main Office',   status:'Present' },
    { empId:'EMP007', name:'Anna Thompson',   initials:'AT', color:'#EC4899', dept:'Marketing',   checkIn:'09:15 AM', checkOut:'05:45 PM', hours:'8h 30m', location:'Branch Office', status:'Present' },
    { empId:'EMP008', name:'David Kim',       initials:'DK', color:'#6366F1', dept:'Finance',     checkIn:'--',       checkOut:'--',        hours:'--',     location:'--',            status:'Absent'  },
  ],
  week: [
    { empId:'EMP001', name:'Sarah Johnson',   initials:'SJ', color:'#8B5CF6', dept:'Engineering', checkIn:'09:00 AM', checkOut:'05:30 PM', hours:'42h 00m', location:'Main Office',   status:'Present' },
    { empId:'EMP002', name:'Michael Chen',    initials:'MC', color:'#06B6D4', dept:'Product',     checkIn:'08:55 AM', checkOut:'05:45 PM', hours:'43h 10m', location:'Main Office',   status:'Present' },
    { empId:'EMP003', name:'Emily Davis',     initials:'ED', color:'#F59E0B', dept:'Design',      checkIn:'09:22 AM', checkOut:'05:30 PM', hours:'40h 40m', location:'Main Office',   status:'Late'    },
