<%
const pageTitle = 'Location Settings';
const pageDate  = 'Office radius, site mapping, and device sync preferences';
%>
<%- include('partials/header', { pageTitle, pageDate, page: 'settings' }) %>

<div style="display:flex; justify-content: flex-end; margin-bottom: 24px;">
  <a href="/settings" class="btn btn-outline" style="text-decoration:none;">← Back to Settings</a>
</div>

<div class="settings-grid">
  <div class="card">
    <div class="card-title">📍 Geofence Defaults</div>
    <div class="setting-group">
      <label class="setting-label">Default Geo-fence Radius (m)</label>
      <input class="setting-input" type="number" value="100" />
    </div>
    <div class="toggle-wrap" style="margin-top: 14px;">
      <div class="toggle-info">
        <div class="tname">Strict Geofence Enforcement</div>
        <div class="tdesc">Block check-ins outside radius</div>
      </div>
      <label class="toggle">
        <input type="checkbox" checked />
        <span class="toggle-slider"></span>
      </label>
    </div>
    <button class="btn btn-primary" style="margin-top: 14px;" onclick="showToast('Location settings saved','success')">Save Changes</button>
  </div>
</div>

<%- include('partials/footer') %>

