<%
const pageTitle = 'Payroll Management';
const pageDate  = 'June 2026 • ' + payroll.length + ' employees';
const totalGross= stats.totalGross;
const totalNet  = stats.totalNet;
const paidCount = stats.paidCount;
const otHours   = stats.otHours;
%>
<%- include('partials/header', { pageTitle, pageDate, page: 'payroll' }) %>

<div class="page-header" style="margin-bottom: 24px;">
  <div>
    <div class="page-header-title" style="font-size: 20px;">Payroll Management</div>
    <div class="page-header-sub"><%= pageDate %></div>
  </div>
  <div style="display:flex;gap:12px;">
    <button class="btn btn-outline" onclick="exportPayroll()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export
    </button>
    <button class="btn btn-primary" onclick="generatePayroll()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      Generate Payroll
    </button>
  </div>
</div>

<!-- ── TOP STATS ────────────────────────────────────────────────────────── -->
<div class="stats-grid" style="grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 24px;">
  <div class="card" style="padding: 24px; position: relative; overflow: hidden;">
    <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(34, 197, 94, 0.1); color: #22c55e; display: flex; align-items: center; justify-content: center; font-size: 16px; margin-bottom: 16px;">$</div>
    <div style="font-size: 24px; font-weight: 800; color: var(--text-primary);">$<%= totalGross.toLocaleString() %></div>
    <div style="font-size: 12.5px; color: var(--text-secondary); margin-bottom: 6px;">Total Gross Pay</div>
    <div style="font-size: 11px; font-weight: 600; color: #16a34a; display: flex; align-items: center; gap: 4px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      +4.2% vs last month
    </div>
    <!-- Simple decorative line chart SVG in background -->
    <svg style="position: absolute; right: 20px; top: 20px; opacity: 0.3; width: 60px; height: 30px;" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M0,25 L30,15 L60,20 L100,5" fill="none" stroke="#22c55e" stroke-width="3"/></svg>
  </div>
  <div class="card" style="padding: 24px; position: relative; overflow: hidden;">
    <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(34, 197, 94, 0.1); color: #22c55e; display: flex; align-items: center; justify-content: center; font-size: 16px; margin-bottom: 16px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    </div>
    <div style="font-size: 24px; font-weight: 800; color: var(--text-primary);">$<%= totalNet.toLocaleString() %></div>
    <div style="font-size: 12.5px; color: var(--text-secondary); margin-bottom: 6px;">Total Net Pay</div>
    <div style="font-size: 11px; font-weight: 600; color: #16a34a; display: flex; align-items: center; gap: 4px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      +3.8% vs last month
    </div>
    <svg style="position: absolute; right: 20px; top: 20px; opacity: 0.3; width: 60px; height: 30px;" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M0,20 L40,10 L70,15 L100,2" fill="none" stroke="#22c55e" stroke-width="3"/></svg>
  </div>
  <div class="card" style="padding: 24px; position: relative; overflow: hidden;">
    <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(34, 197, 94, 0.1); color: #22c55e; display: flex; align-items: center; justify-content: center; font-size: 16px; margin-bottom: 16px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
    <div style="font-size: 24px; font-weight: 800; color: var(--text-primary);"><%= paidCount %>/12</div>
    <div style="font-size: 12.5px; color: var(--text-secondary); margin-bottom: 6px;">Employees Paid</div>
    <div style="font-size: 11px; font-weight: 600; color: transparent; display: flex; align-items: center; gap: 4px;">&nbsp;</div>
    <svg style="position: absolute; right: 20px; top: 20px; opacity: 0.3; width: 60px; height: 30px;" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M0,25 L30,5 L60,10 L100,0" fill="none" stroke="#22c55e" stroke-width="3"/></svg>
  </div>
  <div class="card" style="padding: 24px; position: relative; overflow: hidden;">
    <div style="width: 36px; height: 36px; border-radius: 8px; background: rgba(245, 158, 11, 0.1); color: #f59e0b; display: flex; align-items: center; justify-content: center; font-size: 16px; margin-bottom: 16px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <div style="font-size: 24px; font-weight: 800; color: var(--text-primary);"><%= otHours %>h</div>
    <div style="font-size: 12.5px; color: var(--text-secondary); margin-bottom: 6px;">Overtime Hours</div>
    <div style="font-size: 11px; font-weight: 600; color: #dc2626; display: flex; align-items: center; gap: 4px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="12" height="12"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg>
      -1.2% vs last month
    </div>
    <svg style="position: absolute; right: 20px; top: 20px; opacity: 0.3; width: 60px; height: 30px;" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M0,5 L30,15 L60,10 L100,25" fill="none" stroke="#f59e0b" stroke-width="3"/></svg>
  </div>
</div>

<!-- ── MIDDLE SECTION ─────────────────────────────────────────────────────── -->
<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 24px;">
  <!-- Department Payroll -->
  <div class="card" style="padding: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
      <div>
        <div style="font-size: 15px; font-weight: 700; color: var(--text-primary);">Department Payroll</div>
        <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">Gross pay distribution - June 2026</div>
      </div>
      <button class="btn-icon" style="width:28px;height:28px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg></button>
    </div>
    
    <% 
      const deptPay = stats.deptPay;
    %>
    <div style="display: flex; flex-direction: column; gap: 14px;">
      <% deptPay.forEach(d => { %>
      <div>
        <div style="display: flex; justify-content: space-between; font-size: 12.5px; margin-bottom: 4px;">
          <span style="font-weight: 500; color: var(--text-primary);"><%= d.name %></span>
          <span style="color: var(--text-muted);"><%= d.count %> emp &nbsp; <strong style="color: var(--text-primary);">$<%= d.val.toLocaleString() %></strong></span>
        </div>
        <div style="height: 6px; background: var(--border); border-radius: 3px; overflow: hidden;">
          <div style="height: 100%; width: <%= d.pct %>%; background: #4ade80; border-radius: 3px;"></div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Payment Status -->
  <div class="card" style="padding: 24px; display: flex; flex-direction: column;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
      <div>
        <div style="font-size: 15px; font-weight: 700; color: var(--text-primary);">Payment Status</div>
        <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">Current period</div>
      </div>
      <button class="btn-icon" style="width:28px;height:28px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></button>
    </div>
    
    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 30px;">
      <!-- Donut Chart representation -->
      <div style="position: relative; width: 120px; height: 120px; border-radius: 50%; background: conic-gradient(#ef4444 0% 8%, #f59e0b 8% 25%, #eab308 25% 42%, #22c55e 42% 100%); display: flex; align-items: center; justify-content: center;">
        <div style="width: 96px; height: 96px; background: var(--bg-card); border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center;">
          <div style="font-size: 20px; font-weight: 800; color: var(--text-primary);"><%= stats.paidCount %></div>
          <div style="font-size: 11px; color: var(--text-muted);">Paid</div>
        </div>
      </div>
      
      <!-- Legend -->
      <div style="width: 100%; display: flex; flex-direction: column; gap: 10px;">
        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px;">
          <div style="display: flex; align-items: center; gap: 8px;"><div style="width:8px;height:8px;border-radius:50%;background:#22c55e;"></div><span style="color:var(--text-primary);font-weight:500;">Paid</span></div>
          <div><strong style="color:var(--text-primary);"><%= stats.paidCount %></strong> <span style="color:var(--text-muted);font-size:11.5px;margin-left:4px;"><%= payroll.length ? Math.round(stats.paidCount/payroll.length*100) : 0 %>%</span></div>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px;">
          <div style="display: flex; align-items: center; gap: 8px;"><div style="width:8px;height:8px;border-radius:50%;background:#eab308;"></div><span style="color:var(--text-primary);font-weight:500;">Pending</span></div>
          <div><strong style="color:var(--text-primary);">2</strong> <span style="color:var(--text-muted);font-size:11.5px;margin-left:4px;">17%</span></div>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px;">
          <div style="display: flex; align-items: center; gap: 8px;"><div style="width:8px;height:8px;border-radius:50%;background:#f59e0b;"></div><span style="color:var(--text-primary);font-weight:500;">Processing</span></div>
          <div><strong style="color:var(--text-primary);"><%= payroll.length - stats.paidCount %></strong> <span style="color:var(--text-muted);font-size:11.5px;margin-left:4px;"><%= payroll.length ? Math.round((payroll.length-stats.paidCount)/payroll.length*100) : 0 %>%</span></div>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 13px;">
          <div style="display: flex; align-items: center; gap: 8px;"><div style="width:8px;height:8px;border-radius:50%;background:#ef4444;"></div><span style="color:var(--text-primary);font-weight:500;">On Hold</span></div>
          <div><strong style="color:var(--text-primary);">1</strong> <span style="color:var(--text-muted);font-size:11.5px;margin-left:4px;">8%</span></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── TABLE SECTION ──────────────────────────────────────────────────────── -->
<div class="card" style="padding: 0; overflow: hidden;">
  <div style="padding: 16px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
    <div style="font-size: 14px; font-weight: 600; color: var(--text-primary); margin-right: auto;">Employee Payroll</div>
    <select class="filter-select" style="min-width: 140px; padding: 6px 12px; font-size: 12.5px;">
      <option>June</option><option>May</option><option>April</option>
    </select>
    <select class="filter-select" style="min-width: 160px; padding: 6px 12px; font-size: 12.5px;">
      <option>All Departments</option><option>Engineering</option><option>Sales</option>
    </select>
    <select class="filter-select" style="min-width: 160px; padding: 6px 12px; font-size: 12.5px;">
      <option>All Locations</option><option>Main Office</option><option>Remote</option>
    </select>
    <select class="filter-select" style="min-width: 120px; padding: 6px 12px; font-size: 12.5px;">
      <option>All Statuses</option><option>Paid</option><option>Pending</option>
    </select>
    <div style="font-size: 12px; color: var(--text-muted); margin-left: auto;"><%= payroll.length %> records</div>
  </div>
  
  <div class="table-scroll">
  <table class="data-table" style="width: 100%;">
    <thead>
      <tr>
        <th style="padding: 16px 24px;">EMP ID</th>
        <th>NAME</th>
        <th>DEPARTMENT</th>
        <th class="payroll-hide-mobile">REG HRS</th>
        <th class="payroll-hide-mobile">OT HRS</th>
        <th>GROSS PAY</th>
        <th>NET PAY</th>
        <th>STATUS</th>
        <th style="width: 40px;"></th>
      </tr>
    </thead>
    <tbody>
      <% 
        const prRows = payroll;
        
        prRows.forEach(r => { 
          const inits = r.name.split(' ').map(n=>n[0]).join('');
          let stBadge = '';
          if(r.st === 'Paid') stBadge = `<span class="badge-pay badge-pay-paid"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="10" height="10"><polyline points="20 6 9 17 4 12"/></svg>Paid</span>`;
          else if(r.st === 'Processing') stBadge = `<span class="badge-pay badge-pay-proc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="10" height="10"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Processing</span>`;
          else if(r.st === 'Pending') stBadge = `<span class="badge-pay badge-pay-pend"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="10" height="10"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Pending</span>`;
          else if(r.st === 'On Hold') stBadge = `<span class="badge-pay badge-pay-hold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="10" height="10"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>On Hold</span>`;
      %>
      <tr>
        <td style="padding: 14px 24px; font-size: 12.5px; font-weight: 600; color: #16a34a;"><%= r.id %></td>
        <td>
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:28px;height:28px;border-radius:50%;background:<%= r.clr %>;color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;"><%= inits %></div>
            <div>
              <div style="font-size:13.5px;font-weight:600;color:var(--text-primary);"><%= r.name.length > 15 ? r.name.substring(0,15)+'...' : r.name %></div>
              <div style="font-size:11px;color:var(--text-muted);"><%= r.loc %></div>
            </div>
          </div>
        </td>
        <td style="font-size:12.5px;color:var(--text-secondary);"><%= r.dept %></td>
        <td class="payroll-hide-mobile" style="font-size:12.5px;color:var(--text-primary);font-weight:500;"><%= r.rhr %></td>
        <td class="payroll-hide-mobile" style="font-size:12.5px;color:#f59e0b;font-weight:600;"><%= r.ohr %></td>
        <td style="font-size:13px;font-weight:600;color:var(--text-primary);"><%= r.gp %></td>
        <td style="font-size:13px;font-weight:600;color:#16a34a;"><%= r.np %></td>
        <td><%- stBadge %></td>
        <td style="color:var(--text-muted);text-align:center;cursor:pointer;">⋮</td>
      </tr>
      <% }) %>
    </tbody>
    <tfoot style="border-top: 1px solid var(--border);">
      <tr>
        <td colspan="3" style="padding: 16px 24px; font-size: 12px; font-weight: 700; color: var(--text-secondary); text-align: right;">TOTALS</td>
        <td style="font-size:12.5px;font-weight:700;color:var(--text-primary);"><%= prRows.reduce((a,b)=>a+parseInt(b.rhr),0) %>h</td>
        <td style="font-size:12.5px;font-weight:700;color:#f59e0b;">+<%= stats.otHours %>h</td>
        <td style="font-size:13px;font-weight:700;color:var(--text-primary);">$<%= stats.totalGross.toLocaleString() %></td>
        <td style="font-size:13px;font-weight:700;color:#16a34a;">$<%= stats.totalNet.toLocaleString() %></td>
        <td colspan="2" style="font-size:12px;color:var(--text-muted);"><%= stats.paidCount %> paid</td>
      </tr>
    </tfoot>
  </table>
  </div>
  
  <div class="payroll-cta-row" style="padding: 16px 24px; background: rgba(34,197,94,0.05); display: flex; align-items: center; justify-content: space-between;">
    <div style="display: flex; align-items: center; gap: 12px;">
      <div style="color: #16a34a;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
      <div>
        <div style="font-size: 13.5px; font-weight: 700; color: var(--text-primary);">Ready to process payments</div>
        <div style="font-size: 11.5px; color: var(--text-secondary);"><%= payroll.length - stats.paidCount %> employees pending · estimated $<%= stats.totalGross.toLocaleString() %> total disbursement</div>
      </div>
    </div>
    <div style="display: flex; gap: 10px;">
      <button class="btn btn-outline" style="font-size: 12.5px; padding: 8px 14px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Export CSV</button>
      <button class="btn btn-primary" style="font-size: 12.5px; padding: 8px 16px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 5 5 12"/></svg> Process Payments</button>
    </div>
  </div>
</div>

<script>
function exportPayroll() { showToast('Exporting Payroll...', 'info'); }
function generatePayroll() { showToast('Generating new payroll period...', 'success'); }
</script>

<%- include('partials/footer') %>
