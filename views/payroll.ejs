<%
const pageTitle = 'Payroll';
const pageDate  = new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
const totalNet  = payroll.reduce((s,p)=>s+p.net,0);
const totalDed  = payroll.reduce((s,p)=>s+p.deductions,0);
%>
<%- include('partials/header', { pageTitle, pageDate, page }) %>

<div class="page-header">
  <div>
    <div class="page-header-title">Payroll Management</div>
    <div class="page-header-sub">June 2026 payroll summary</div>
  </div>
  <div style="display:flex;gap:8px;">
    <button class="btn btn-outline" id="btnAllPayslips" onclick="openAllPayslips()">📄 All Payslips</button>
    <button class="btn btn-primary" id="btnExportPayroll" onclick="exportPayroll()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export CSV
    </button>
  </div>
</div>

<!-- Summary Stats -->
<div class="stats-grid" style="margin-bottom:20px;">
  <div class="stat-card">
    <div class="stat-icon-wrap total">💰</div>
    <div>
      <div class="stat-num">$<%= totalNet.toLocaleString() %></div>
      <div class="stat-label">Total Net Payout</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap present">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </div>
    <div>
      <div class="stat-num"><%= payroll.length %></div>
      <div class="stat-label">Employees Processed</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap late">📉</div>
    <div>
      <div class="stat-num">$<%= totalDed.toLocaleString() %></div>
      <div class="stat-label">Total Deductions</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap absent">📋</div>
    <div>
      <div class="stat-num" style="font-size:16px;color:#d97706;">Pending</div>
      <div class="stat-label">Approval Status</div>
    </div>
  </div>
</div>

<!-- Payroll Table -->
<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>EMP ID</th><th>NAME</th><th>DEPARTMENT</th><th>HOURS</th>
        <th>BASE SALARY</th><th>DEDUCTIONS</th><th>NET PAY</th><th>ACTION</th>
      </tr>
    </thead>
    <tbody>
      <% payroll.forEach(function(p){ %>
      <tr>
        <td class="emp-id-cell"><%= p.id %></td>
        <td>
          <div class="emp-cell">
            <div class="emp-avatar" style="background:<%= p.color %>"><%= p.initials %></div>
            <div>
              <div class="emp-name"><%= p.name %></div>
              <div style="font-size:11.5px;color:#94a3b8;"><%= p.email %></div>
            </div>
          </div>
        </td>
        <td style="color:#64748b;font-size:13px;"><%= p.department %></td>
        <td style="font-size:13px;color:#475569;"><%= p.hoursWorked %>h</td>
        <td class="amount">$<%= p.salary.toLocaleString() %></td>
        <td class="amount" style="color:#dc2626;">-$<%= p.deductions.toLocaleString() %></td>
        <td class="amount green">$<%= p.net.toLocaleString() %></td>
        <td>
          <div style="display:flex;gap:6px;">
            <button class="btn btn-outline" style="font-size:11.5px;padding:4px 10px;"
              onclick="openPayslip('<%= p.id %>','<%= p.name %>','<%= p.department %>','<%= p.position %>','<%= p.email %>','<%= p.hoursWorked %>',<%= p.salary %>,<%= p.deductions %>,<%= p.net %>,'<%= p.initials %>','<%= p.color %>')">
              📄 Payslip
            </button>
            <button class="btn btn-primary" style="font-size:11.5px;padding:4px 10px;" onclick="approvePayroll('<%= p.id %>','<%= p.name %>',this)">
              ✅ Approve
            </button>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- ══ PAYSLIP MODAL ═══════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modalPayslip">
  <div class="modal modal-lg">
    <div class="modal-header">
      <div class="modal-title">📄 Payslip</div>
      <button class="modal-close" onclick="closeModal('modalPayslip')">✕</button>
    </div>
    <div class="modal-body" style="padding:0;">
      <div class="payslip" id="payslipContent">
        <!-- Filled by JS -->
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modalPayslip')">Close</button>
      <button class="btn btn-outline" onclick="printPayslip()" style="color:#3730a3;border-color:#3730a3;">
        🖨 Print
      </button>
      <button class="btn btn-primary" onclick="downloadPayslipPDF()">⬇ Download</button>
    </div>
  </div>
</div>

<!-- Hidden print area -->
<div class="print-only" id="printArea" style="display:none;"></div>

<script>
function openPayslip(id, name, dept, position, email, hours, salary, deductions, net, initials, color) {
  const now      = new Date();
  const month    = now.toLocaleString('default', { month:'long', year:'numeric' });
  const tax      = Math.floor(salary * 0.05);
  const insurance= Math.floor(salary * 0.03);
  const other    = deductions - tax - insurance;

  document.getElementById('payslipContent').innerHTML = `
    <div class="payslip-header">
      <div>
        <div class="payslip-brand">📍 GeoLock</div>
        <div class="payslip-subtitle">Employee Payslip — Confidential</div>
      </div>
      <div class="payslip-period">
        <div style="font-weight:700;color:#1e293b;">${month}</div>
        <div>Pay Period: 01–${now.getDate()} ${month}</div>
        <div>Generated: ${now.toLocaleDateString()}</div>
      </div>
    </div>

    <div class="payslip-emp">
      <div class="payslip-emp-item"><div class="lbl">Employee ID</div><div class="val">${id}</div></div>
      <div class="payslip-emp-item"><div class="lbl">Full Name</div><div class="val">${name}</div></div>
      <div class="payslip-emp-item"><div class="lbl">Department</div><div class="val">${dept}</div></div>
      <div class="payslip-emp-item"><div class="lbl">Position</div><div class="val">${position || 'Employee'}</div></div>
      <div class="payslip-emp-item"><div class="lbl">Email</div><div class="val">${email}</div></div>
      <div class="payslip-emp-item"><div class="lbl">Hours Worked</div><div class="val">${hours}h</div></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div>
        <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Earnings</div>
        <table class="payslip-table">
          <thead><tr><th>Description</th><th style="text-align:right;">Amount</th></tr></thead>
          <tbody>
            <tr><td>Base Salary</td><td style="text-align:right;font-weight:600;">$${salary.toLocaleString()}</td></tr>
            <tr><td>Overtime Pay</td><td style="text-align:right;">$0</td></tr>
            <tr><td>Allowances</td><td style="text-align:right;">$0</td></tr>
            <tr style="border-top:2px solid #e2e8f0;">
              <td style="font-weight:700;">Gross Pay</td>
              <td style="text-align:right;font-weight:700;color:#16a34a;">$${salary.toLocaleString()}</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div>
        <div style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Deductions</div>
        <table class="payslip-table">
          <thead><tr><th>Description</th><th style="text-align:right;">Amount</th></tr></thead>
          <tbody>
            <tr><td>Income Tax (5%)</td><td style="text-align:right;color:#dc2626;">-$${tax.toLocaleString()}</td></tr>
            <tr><td>Health Insurance (3%)</td><td style="text-align:right;color:#dc2626;">-$${insurance.toLocaleString()}</td></tr>
            <tr><td>Other Deductions</td><td style="text-align:right;color:#dc2626;">-$${Math.max(0,other).toLocaleString()}</td></tr>
            <tr style="border-top:2px solid #e2e8f0;">
              <td style="font-weight:700;">Total Deductions</td>
              <td style="text-align:right;font-weight:700;color:#dc2626;">-$${deductions.toLocaleString()}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="payslip-net">
      <div class="payslip-net-label">💵 Net Pay (Take Home)</div>
      <div class="payslip-net-amount">$${net.toLocaleString()}</div>
    </div>

    <div style="margin-top:20px;padding-top:16px;border-top:1px solid #e2e8f0;display:flex;justify-content:space-between;font-size:11px;color:#94a3b8;">
      <span>This is a computer-generated payslip. No signature required.</span>
      <span>GeoLock Corp © ${now.getFullYear()}</span>
    </div>
  `;
  openModal('modalPayslip');
}

function printPayslip() {
  const content  = document.getElementById('payslipContent').innerHTML;
  const printWin = window.open('', '_blank', 'width=800,height=600');
  printWin.document.write(`
    <html><head>
      <title>Payslip</title>
      <link href="/css/style.css" rel="stylesheet"/>
      <style>body{padding:20px;} @media print{body{margin:0;padding:0;}}</style>
    </head><body>
      <div class="payslip">${content}</div>
      <script>window.onload=()=>{window.print();window.close();}<\/script>
    </body></html>`);
  printWin.document.close();
  showToast('Opening print preview...', 'info');
}

function downloadPayslipPDF() {
  showToast('Payslip downloaded!', 'success');
  printPayslip();
}

function approvePayroll(id, name, btn) {
  btn.textContent  = '✅ Approved';
  btn.disabled     = true;
  btn.style.background = '#16a34a';
  showToast(`Payroll approved for ${name}`, 'success');
}

function openAllPayslips() {
  showToast('Generating all payslips...', 'info');
}

function exportPayroll() {
  const rows = [['EMP ID','Name','Department','Hours','Base Salary','Deductions','Net Pay']];
  document.querySelectorAll('.data-table tbody tr').forEach(row => {
    const cells = row.querySelectorAll('td');
    if (cells.length) rows.push(Array.from(cells).slice(0,7).map(c => c.innerText.trim()));
  });
  const csv = rows.map(r => r.map(c => '"' + c + '"').join(',')).join('\n');
  const a   = document.createElement('a');
  a.href    = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
  a.download= 'payroll_' + new Date().toISOString().slice(0,7) + '.csv';
  a.click();
  showToast('Payroll exported!', 'success');
}
</script>

<%- include('partials/footer') %>
