<%
const pageTitle = 'Payroll Settings';
const pageDate  = 'Pay cycle, overtime rates, and approval workflows';
const actions = `
  <a href="/settings" class="btn btn-outline" style="text-decoration:none;">← Back to Settings</a>
`;
%>
<%- include('partials/header', { pageTitle, pageDate, page: 'settings', actions }) %>

<div class="settings-grid">
  <div class="card">
    <div class="card-title">Payroll Processing</div>
    <div class="setting-group">
      <label class="setting-label">Pay Cycle</label>
      <select class="setting-input">
        <option>Monthly</option>
        <option>Bi-Weekly</option>
        <option>Weekly</option>
      </select>
    </div>
    <div class="setting-group">
      <label class="setting-label">Overtime Rate Multiplier</label>
      <input class="setting-input" type="number" step="0.5" value="1.5" />
    </div>
    <button class="btn btn-primary" style="margin-top: 14px;" onclick="showToast('Payroll settings saved','success')">Save Changes</button>
  </div>
</div>

<%- include('partials/footer') %>

