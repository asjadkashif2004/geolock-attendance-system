<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GeoLock – Attendance Management</title>
  <meta name="description" content="GeoLock employee attendance management dashboard" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>

<!-- ── SIDEBAR ─────────────────────────────────────────────────────────── -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">📍</div>
    <div class="logo-text">
      <div class="brand">GeoLock</div>
      <div class="role">Admin</div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <a href="/dashboard"  class="nav-item <%= page==='dashboard'  ? 'active' : '' %>">
      <%- svgDashboard() %> Dashboard
    </a>
    <a href="/employees"  class="nav-item <%= page==='employees'  ? 'active' : '' %>">
      <%- svgEmployees() %> Employees
    </a>
    <a href="/attendance" class="nav-item <%= page==='attendance' ? 'active' : '' %>">
      <%- svgAttendance() %> Attendance
    </a>
    <a href="/locations"  class="nav-item <%= page==='locations'  ? 'active' : '' %>">
      <%- svgLocations() %> Locations
    </a>
    <a href="/reports"    class="nav-item <%= page==='reports'    ? 'active' : '' %>">
      <%- svgReports() %> Reports
    </a>
    <a href="/payroll"    class="nav-item <%= page==='payroll'    ? 'active' : '' %>">
      <%- svgPayroll() %> Payroll
    </a>
    <a href="/settings"   class="nav-item <%= page==='settings'   ? 'active' : '' %>">
      <%- svgSettings() %> Settings
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="user-card">
      <div class="user-avatar">A</div>
      <div class="user-info">
        <div class="uname">Admin User</div>
        <div class="urole">Super Admin</div>
      </div>
    </div>
  </div>
</aside>

<!-- ── MAIN ────────────────────────────────────────────────────────────── -->
<div class="main">
  <header class="topbar">
    <div class="topbar-left">
      <div class="page-title"><%- title %></div>
      <div class="page-date"><%= dateStr %></div>
    </div>
    <div class="topbar-right">
      <button class="btn-icon" title="Notifications">🔔</button>
      <button class="btn-icon" title="Toggle theme">🌙</button>
    </div>
  </header>

  <div class="content">
    <%- body %>
  </div>
</div>

<script src="/js/app.js"></script>
</body>
</html>

<%
/* ─── SVG helpers ─────────────────────────────────────────────────────────── */
function svgDashboard(){
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`;
}
function svgEmployees(){
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;
}
function svgAttendance(){
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`;
}
function svgLocations(){
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`;
}
function svgReports(){
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`;
}
function svgPayroll(){
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`;
}
function svgSettings(){
  return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`;
}
%>
