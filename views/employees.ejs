<%
const pageTitle = 'Employees';
const pageDate  = new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
%>
<%- include('partials/header', { pageTitle, pageDate, page }) %>

<div class="page-header">
  <div>
    <div class="page-header-title">All Employees</div>
    <div class="page-header-sub"><%= employees.length %> employees registered</div>
  </div>
  <button class="btn btn-primary" id="btnAddEmployee">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Add Employee
  </button>
</div>

<div class="filter-bar" style="margin-bottom:20px;">
  <div class="search-wrap">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input class="search-input" id="empSearch" type="text" placeholder="Search employees..." oninput="filterEmployees()" />
  </div>
  <select class="filter-select" id="deptFilter" onchange="filterEmployees()">
    <option value="">All Departments</option>
    <option>Engineering</option><option>Product</option><option>Design</option>
    <option>Sales</option><option>HR</option><option>Marketing</option><option>Finance</option>
  </select>
  <select class="filter-select" id="statusFilt" onchange="filterEmployees()">
    <option value="">All Statuses</option>
    <option>Active</option><option>On Leave</option>
  </select>
</div>

<div class="employees-grid" id="empGrid">
  <% employees.forEach(function(e){ %>
  <div class="emp-card"
       data-name="<%= e.name.toLowerCase() %>"
       data-dept="<%= e.department.toLowerCase() %>"
       data-status="<%= e.status %>">
    <div class="emp-card-avatar" style="background:<%= e.color %>"><%= e.initials %></div>
    <div class="emp-card-name"><%= e.name %></div>
    <div class="emp-card-pos"><%= e.position %></div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center;margin:4px 0;">
      <span style="background:#ede9fe;color:#7c3aed;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;">
        <%= e.department %>
      </span>
      <span class="badge <%= e.status==='Active' ? 'badge-active' : 'badge-leave' %>" style="font-size:11px;">
        <%= e.status %>
      </span>
    </div>
    <div class="emp-card-email"><%= e.email %></div>
    <div style="color:#64748b;font-size:12px;"><%= e.phone %></div>
    <div style="font-size:11px;color:#94a3b8;">Joined: <%= e.joinDate %></div>
    <div style="display:flex;gap:8px;margin-top:8px;">
      <button class="btn btn-outline" style="font-size:12px;padding:5px 12px;">View</button>
      <button class="btn btn-primary"  style="font-size:12px;padding:5px 12px;">Edit</button>
    </div>
  </div>
  <% }) %>
</div>
<div id="empEmpty" class="empty-state" style="display:none;">No employees found.</div>

<script>
function filterEmployees(){
  const q    = document.getElementById('empSearch').value.toLowerCase();
  const dept = document.getElementById('deptFilter').value.toLowerCase();
  const stat = document.getElementById('statusFilt').value;
  const cards = document.querySelectorAll('#empGrid .emp-card');
  let vis = 0;
  cards.forEach(c=>{
    const ok = (!q || c.dataset.name.includes(q) || c.dataset.dept.includes(q))
            && (!dept || c.dataset.dept === dept)
            && (!stat || c.dataset.status === stat);
    c.style.display = ok ? '' : 'none';
    if(ok) vis++;
  });
  document.getElementById('empEmpty').style.display = vis===0 ? '' : 'none';
}
</script>

<%- include('partials/footer') %>
