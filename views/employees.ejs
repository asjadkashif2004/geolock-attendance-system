<%
const pageTitle = 'Employees';
const pageDate  = new Date().toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
const colors    = ['#8B5CF6','#06B6D4','#F59E0B','#EF4444','#10B981','#3B82F6','#EC4899','#6366F1','#14b8a6','#f97316'];
const actions = `
  <button class="btn btn-primary" id="btnAddEmployee" onclick="openModal('modalAddEmp')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Add Employee
  </button>
`;
%>
<%- include('partials/header', { pageTitle, pageDate, page, actions }) %>

<div class="filter-bar" style="margin-bottom:24px;">
  <div class="search-wrap">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input class="search-input" id="empSearch" type="text" placeholder="Search employees..." oninput="filterEmployees()" />
  </div>
  <select class="filter-select" id="deptFilter" onchange="filterEmployees()">
    <option value="">All Departments</option>
    <option>Engineering</option><option>Product</option><option>Design</option>
    <option>Sales</option><option>HR</option><option>Marketing</option><option>Finance</option>
  </select>
  <select class="filter-select" id="statusFilt" onchange="filterEmployees()">
    <option value="">All Statuses</option>
    <option>Active</option><option>On Leave</option>
  </select>
</div>

<div class="employees-grid" id="empGrid">
  <% employees.forEach(function(e){
    const eName   = e.name       || 'Unknown';
    const eDept   = e.department || 'N/A';
    const ePos    = e.position   || '--';
    const eEmail  = e.email      || '--';
    const ePhone  = e.phone      || '--';
    const eJoin   = e.joinDate   || e.joindate || '--';
    const eStatus = e.status     || 'Active';
    const eColor  = e.color      || '#6366F1';
    const eInits  = e.initials   || eName.split(' ').map(w=>w[0]).join('').toUpperCase().substring(0,2);
    const eSalary = e.monthly_salary || 5000;
    const eId     = e.id         || '';
  %>
  <div class="emp-card"
       data-name="<%= eName.toLowerCase() %>"
       data-dept="<%= eDept.toLowerCase() %>"
       data-status="<%= eStatus %>">
    <div class="emp-card-avatar" style="background:<%= eColor %>"><%= eInits %></div>
    <div class="emp-card-name"><%= eName %></div>
    <div class="emp-card-pos"><%= ePos %></div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center;margin:4px 0;">
      <span style="background:#ede9fe;color:#7c3aed;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;"><%= eDept %></span>
      <span class="badge <%= eStatus==='Active' ? 'badge-active' : 'badge-leave' %>" style="font-size:11px;"><%= eStatus %></span>
    </div>
    <div class="emp-card-email"><%= eEmail %></div>
    <div style="color:#64748b;font-size:12px;"><%= ePhone %></div>
    <div style="font-size:11px;color:#94a3b8;">Joined: <%= eJoin %></div>
    <div style="display:flex;gap:8px;margin-top:8px;">
      <button class="btn btn-outline" style="color:#ef4444;border-color:#fca5a5;font-size:12px;padding:5px 12px;" type="button"
        onclick="deleteEmployee('<%= eId %>', '<%= eName.replace(/'/g,"\\'") %>')">Delete</button>
      <button class="btn btn-primary" style="font-size:12px;padding:5px 12px;" type="button"
        onclick="editEmployee('<%= eId %>', '<%= eName.replace(/'/g,"\\'") %>', '<%= ePos.replace(/'/g,"\\'") %>', '<%= eDept %>', '<%= eEmail %>', '<%= ePhone %>', '<%= eJoin %>', '<%= eStatus %>', '<%= eSalary %>')">Edit</button>
    </div>
  </div>
  <% }) %>
</div>
<div id="empEmpty" class="empty-state" style="display:none;">No employees found.</div>

<!-- ══ ADD EMPLOYEE MODAL ══════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modalAddEmp">
  <div class="modal modal-lg">
    <div class="modal-header">
      <div class="modal-title" style="display: flex; align-items: center; gap: 8px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add New Employee
      </div>
      <button class="modal-close" onclick="closeModal('modalAddEmp')">✕</button>
    </div>
    <div class="modal-body">
      <form id="addEmpForm" onsubmit="submitAddEmployee(event)">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">First Name *</label>
            <input class="form-input" id="fName" type="text" placeholder="e.g. John" required />
          </div>
          <div class="form-group">
            <label class="form-label">Last Name *</label>
            <input class="form-input" id="lName" type="text" placeholder="e.g. Doe" required />
          </div>
          <div class="form-group">
            <label class="form-label">Email Address *</label>
            <input class="form-input" id="fEmail" type="email" placeholder="john@geolock.com" required />
          </div>
          <div class="form-group">
            <label class="form-label">Phone Number</label>
            <input class="form-input" id="fPhone" type="tel" placeholder="+1 555-0000" />
          </div>
          <div class="form-group">
            <label class="form-label">Department *</label>
            <select class="form-input" id="fDept" required>
              <option value="">Select Department</option>
              <option>Engineering</option><option>Product</option><option>Design</option>
              <option>Sales</option><option>HR</option><option>Marketing</option><option>Finance</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Position / Role *</label>
            <input class="form-input" id="fPosition" type="text" placeholder="e.g. Software Engineer" required />
          </div>
          <div class="form-group">
            <label class="form-label">Location</label>
            <select class="form-input" id="fLocation">
              <option value="">Select Location</option>
              <% locations.forEach(l => { %>
                <option value="<%= l.name %>"><%= l.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Join Date</label>
            <input class="form-input" id="fJoinDate" type="date" value="<%= new Date().toISOString().slice(0,10) %>" />
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-input" id="fStatus">
              <option>Active</option><option>On Leave</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Monthly Salary ($)</label>
            <input class="form-input" id="fMonthlySalary" type="number" step="100" placeholder="e.g. 5000" value="5000" />
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modalAddEmp')">Cancel</button>
      <button class="btn btn-primary" onclick="submitAddEmployee(event)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Employee
      </button>
    </div>
  </div>
</div>

<!-- ══ EDIT EMPLOYEE MODAL ═════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modalEditEmp">
  <div class="modal modal-lg">
    <div class="modal-header">
      <div class="modal-title" style="display: flex; align-items: center; gap: 8px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit Employee
      </div>
      <button class="modal-close" onclick="closeModal('modalEditEmp')">✕</button>
    </div>
    <div class="modal-body">
      <form id="editEmpForm" onsubmit="submitEditEmployee(event)">
        <input type="hidden" id="editEmpId" />
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Full Name *</label>
            <input class="form-input" id="editName" type="text" required />
          </div>
          <div class="form-group">
            <label class="form-label">Email Address *</label>
            <input class="form-input" id="editEmail" type="email" required />
          </div>
          <div class="form-group">
            <label class="form-label">Phone Number</label>
            <input class="form-input" id="editPhone" type="tel" />
          </div>
          <div class="form-group">
            <label class="form-label">Department *</label>
            <select class="form-input" id="editDept" required>
              <option value="">Select Department</option>
              <option>Engineering</option><option>Product</option><option>Design</option>
              <option>Sales</option><option>HR</option><option>Marketing</option><option>Finance</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Position / Role *</label>
            <input class="form-input" id="editPosition" type="text" required />
          </div>
          <div class="form-group">
            <label class="form-label">Location</label>
            <select class="form-input" id="editLocation">
              <option value="">Select Location</option>
              <% locations.forEach(l => { %>
                <option value="<%= l.name %>"><%= l.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Join Date</label>
            <input class="form-input" id="editJoinDate" type="date" />
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select class="form-input" id="editStatus">
              <option>Active</option><option>On Leave</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Monthly Salary ($)</label>
            <input class="form-input" id="editMonthlySalary" type="number" step="100" />
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('modalEditEmp')">Cancel</button>
      <button class="btn btn-primary" onclick="submitEditEmployee(event)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><polyline points="20 6 9 17 4 12"/></svg>
        Save Changes
      </button>
    </div>
  </div>
</div>
<script>
const empColors = <%- JSON.stringify(colors) %>;
let empCounter  = <%= employees.length %> + 1;

function filterEmployees(){
  const q    = document.getElementById('empSearch').value.toLowerCase();
  const dept = document.getElementById('deptFilter').value.toLowerCase();
  const stat = document.getElementById('statusFilt').value;
  const cards = document.querySelectorAll('#empGrid .emp-card');
  let vis = 0;
  cards.forEach(c=>{
    const ok = (!q || c.dataset.name.includes(q) || c.dataset.dept.includes(q))
            && (!dept || c.dataset.dept === dept)
            && (!stat || c.dataset.status === stat);
    c.style.display = ok ? '' : 'none';
    if(ok) vis++;
  });
  document.getElementById('empEmpty').style.display = vis===0 ? '' : 'none';
}

async function submitAddEmployee(e) {
  e && e.preventDefault && e.preventDefault();
  const firstName = document.getElementById('fName').value.trim();
  const lastName  = document.getElementById('lName').value.trim();
  const email     = document.getElementById('fEmail').value.trim();
  const phone     = document.getElementById('fPhone').value.trim() || '--';
  const dept      = document.getElementById('fDept').value;
  const position  = document.getElementById('fPosition').value.trim();
  const joinDate  = document.getElementById('fJoinDate').value;
  const status    = document.getElementById('fStatus').value;
  const monthlySalary = parseFloat(document.getElementById('fMonthlySalary').value) || 5000;
  const loc      = document.getElementById('fLocation').value;

  if (!firstName || !lastName || !email || !position || !dept || !phone || !loc || !joinDate || !status) {
    showToast('Please fill in all fields. No fields can be empty.', 'error');
    return;
  }
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email)) {
    showToast('Please enter a valid email address.', 'error');
    return;
  }
  const phoneRegex = /^0-\d{3}-\d{7}$/;
  if (!phoneRegex.test(phone)) {
    showToast('Phone number must be in format: 0-300-0000000', 'error');
    return;
  }

  const fullName = firstName + ' ' + lastName;
  const initials = (firstName[0] + lastName[0]).toUpperCase();
  const color    = empColors[(empCounter - 1) % empColors.length];
  const empId    = 'EMP' + String(empCounter).padStart(3, '0');
  
    const payload = {
      id: empId,
      name: fullName,
      initials,
      color,
      department: dept,
      position,
      email,
      phone,
      status,
      joindate: joinDate,
      monthly_salary: monthlySalary,
      location: loc
    };

  try {
    const res = await fetch('/api/employees', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    if (!res.ok) throw new Error('Failed to save employee to database');

    const badgeCls = status === 'Active' ? 'badge-active' : 'badge-leave';
    const card = document.createElement('div');
    card.className = 'emp-card';
    card.dataset.name   = fullName.toLowerCase();
    card.dataset.dept   = dept.toLowerCase();
    card.dataset.status = status;
    card.innerHTML = `
      <div class="emp-card-avatar" style="background:${color}">${initials}</div>
      <div class="emp-card-name">${fullName}</div>
      <div class="emp-card-pos">${position}</div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center;margin:4px 0;">
        <span style="background:#ede9fe;color:#7c3aed;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;">${dept}</span>
        <span class="badge ${badgeCls}" style="font-size:11px;">${status}</span>
      </div>
      <div class="emp-card-email">${email}</div>
      <div style="color:#64748b;font-size:12px;">${phone}</div>
      <div style="font-size:11px;color:#94a3b8;">Joined: ${joinDate}</div>
      <div style="display:flex;gap:8px;margin-top:8px;">
        <button class="btn btn-outline" style="color:#ef4444;border-color:#fca5a5;font-size:12px;padding:5px 12px;">Delete</button>
        <button class="btn btn-primary" style="font-size:12px;padding:5px 12px;">Edit</button>
      </div>`;

    document.getElementById('empGrid').prepend(card);
    document.getElementById('addEmpForm').reset();
    document.getElementById('fJoinDate').value = new Date().toISOString().slice(0,10);
    closeModal('modalAddEmp');

    empCounter++;
    const count = document.querySelectorAll('#empGrid .emp-card').length;
    document.getElementById('empCount').textContent = count + ' employees registered';
    showToast(`${fullName} added successfully to the database!`, 'success');
  } catch (err) {
    showToast(err.message, 'error');
  }
}

async function deleteEmployee(id, name) {
  if (!confirm(`Are you sure you want to delete ${name}? This action cannot be undone.`)) {
    return;
  }
  try {
    const res = await fetch('/api/employees/' + id, { method: 'DELETE' });
    if (!res.ok) throw new Error('Failed to delete employee from database');
    showToast(`${name} deleted successfully!`, 'success');
    setTimeout(() => window.location.reload(), 800);
  } catch (err) {
    showToast(err.message, 'error');
  }
}

function editEmployee(id, name, position, dept, email, phone, joinDate, status, monthlySalary, location) {
  document.getElementById('editEmpId').value = id;
  document.getElementById('editName').value = name;
  document.getElementById('editPosition').value = position;
  document.getElementById('editDept').value = dept;
  document.getElementById('editEmail').value = email;
  document.getElementById('editPhone').value = phone !== '--' ? phone : '';
  document.getElementById('editJoinDate').value = joinDate;
  document.getElementById('editStatus').value = status;
  document.getElementById('editMonthlySalary').value = monthlySalary || 5000;
  document.getElementById('editLocation').value = location || '';
  openModal('modalEditEmp');
}

async function submitEditEmployee(e) {
  e && e.preventDefault && e.preventDefault();
  const id = document.getElementById('editEmpId').value;
  const name = document.getElementById('editName').value.trim();
  const position = document.getElementById('editPosition').value.trim();
  const dept = document.getElementById('editDept').value;
  const email = document.getElementById('editEmail').value.trim();
  const phone = document.getElementById('editPhone').value.trim() || '--';
  const joinDate = document.getElementById('editJoinDate').value;
  const status = document.getElementById('editStatus').value;
  const monthlySalary = parseFloat(document.getElementById('editMonthlySalary').value) || 5000;
  const loc = document.getElementById('editLocation').value;

  if (!name || !email || !position || !dept || !phone || !loc || !joinDate || !status) {
    showToast('Please fill in all fields. No fields can be empty.', 'error');
    return;
  }
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email)) {
    showToast('Please enter a valid email address.', 'error');
    return;
  }
  const phoneRegex = /^0-\d{3}-\d{7}$/;
  if (!phoneRegex.test(phone)) {
    showToast('Phone number must be in format: 0-300-0000000', 'error');
    return;
  }

    const payload = {
      name,
      department: dept,
      position,
      email,
      phone,
      status,
      joindate: joinDate,
      monthly_salary: monthlySalary,
      location: loc
    };

  try {
    const res = await fetch('/api/employees/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    if (!res.ok) throw new Error('Failed to update employee in database');
    
    showToast(`${name} updated successfully!`, 'success');
    closeModal('modalEditEmp');
    
    // Quick and easy way to reflect changes: reload page
    setTimeout(() => window.location.reload(), 1000);
  } catch (err) {
    showToast(err.message, 'error');
  }
}
</script>

<%- include('partials/footer') %>
